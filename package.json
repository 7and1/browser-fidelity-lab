{
  "name": "browser-fidelity-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "pnpm -r --sort test",
    "lint:content": "node scripts/check-content-policy.mjs",
    "check:open-source": "node scripts/check-open-source-readiness.mjs",
    "check:launch": "node scripts/check-launch-readiness.mjs --public",
    "qa:browser": "node scripts/openclaw-browser-qa.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "ci": "pnpm lint:content && pnpm check:open-source && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "playwright": "^1.49.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
