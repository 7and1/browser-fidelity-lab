---
import { BrowserWorkspace } from "../components/BrowserWorkspace";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sitePages } from "../lib/site-pages";
import type { SitePage } from "../lib/site-pages";

const isSitePage = (page: SitePage | undefined): page is SitePage => Boolean(page);

const qaJobs = [
  "/tools/timezone-ip-mismatch-checker",
  "/tools/mobile-browser-fingerprint-test",
  "/tools/webrtc-leak-test",
  "/tools/playwright-device-preset-generator"
]
  .map((path) => sitePages.find((page) => page.path === path))
  .filter(isSitePage);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Cloak Browser",
  url: "https://cloakbrowser.org/",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any",
  description:
    "QA tools for checking whether browser, IP, locale, timezone, WebRTC, and Playwright settings describe one coherent environment."
};
---

<BaseLayout
  title="Cloak Browser | Browser Consistency Checks for QA Profiles"
  description="Scan browser-visible signals, find IP/timezone/WebRTC mismatches, and export Playwright presets for repeatable QA."
  schema={schema}
>
  <section class="page-shell home-shell">
    <section class="hero-cockpit" aria-labelledby="home-title">
      <div class="hero-copy">
        <p class="eyebrow">Fidelity protection suite</p>
        <h1 id="home-title">Cloak Browser</h1>
        <p class="hero-kicker">
          Verify browser environment consistency before it breaks a QA report,
          preset, or CI run.
        </p>
        <p class="subhead">
          Scan browser-visible state, compare IP, locale, timezone, WebRTC, and runtime signals, then export a coherent
          Playwright preset.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="#scanner">Run global diagnostic scan</a>
          <a class="button secondary" href="#generator">Explore code exports</a>
        </div>
        <div class="workflow-strip command-flow" aria-label="Cloak Browser workflow">
          <span>Scan system signals</span>
          <span>Map timezone and geo</span>
          <span>Fix first</span>
          <span>Generate safe presets</span>
        </div>
      </div>

      <div class="signal-console" aria-label="Example Cloak Browser run">
        <div class="console-head">
          <span class="console-dot"></span>
          <strong>qa-run.cloak-browser</strong>
          <code>score >= 90</code>
        </div>
        <div class="console-score">
          <span>95</span>
          <div>
            <strong>Structure aligned</strong>
            <p>Locale, timezone, device, and route signals describe one profile.</p>
          </div>
        </div>
        <dl class="console-grid">
          <div>
            <dt>Locale</dt>
            <dd>en-US</dd>
          </div>
          <div>
            <dt>Timezone</dt>
            <dd>America/New_York</dd>
          </div>
          <div>
            <dt>Network</dt>
            <dd>GB / ASN</dd>
          </div>
          <div>
            <dt>CI</dt>
            <dd>fail-under 90</dd>
          </div>
        </dl>
        <pre><code>{`use: {
  locale: "en-US",
  timezoneId: "America/New_York",
  hasTouch: false
}`}</code></pre>
      </div>
    </section>

    <section class="growth-strip" aria-labelledby="qa-jobs-title">
      <div>
        <p class="eyebrow">Common QA jobs</p>
        <h2 id="qa-jobs-title">Jump straight to the browser consistency failure you need to prove.</h2>
      </div>
      <div class="growth-link-grid">
        {qaJobs.map((page) => (
          <a class="growth-link" href={page.path}>
            <strong>{page.title}</strong>
            <span>{page.intent}</span>
          </a>
        ))}
      </div>
    </section>

    <BrowserWorkspace client:load />
  </section>
</BaseLayout>
