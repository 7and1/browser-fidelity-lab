---
import { EnvironmentScanner } from "../components/EnvironmentScanner";
import { PresetGenerator } from "../components/PresetGenerator";
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Cloak Browser",
  url: "https://cloakbrowser.org/",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any",
  description:
    "QA tools for checking whether browser, IP, locale, timezone, WebRTC, and Playwright settings describe one coherent environment."
};
---

<BaseLayout
  title="Cloak Browser | Browser Consistency Checks for QA Profiles"
  description="Scan browser-visible signals, find IP/timezone/WebRTC mismatches, and export Playwright presets for repeatable QA."
  schema={schema}
>
  <section class="page-shell home-shell">
    <section class="hero-cockpit" aria-labelledby="home-title">
      <div class="hero-copy">
        <p class="eyebrow">Browser consistency workspace</p>
        <h1 id="home-title">Cloak Browser</h1>
        <p class="hero-kicker">
          Catch profile drift before it breaks a browser test, report, or CI
          run.
        </p>
        <p class="subhead">
          Scan browser-visible state, compare IP, locale, timezone, WebRTC, and
          runtime signals, then export a coherent Playwright preset.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="#scanner">Run scan</a>
          <a class="button secondary" href="/docs/ci-browser-fidelity-checks">CI recipe</a>
        </div>
        <div class="workflow-strip command-flow" aria-label="Cloak Browser workflow">
          <span>Scan</span>
          <span>Fix first</span>
          <span>Export preset</span>
          <span>Fail CI below score</span>
        </div>
      </div>

      <div class="signal-console" aria-label="Example Cloak Browser run">
        <div class="console-head">
          <span class="console-dot"></span>
          <strong>qa-run.cloak-browser</strong>
          <code>score >= 90</code>
        </div>
        <div class="console-score">
          <span>87</span>
          <div>
            <strong>Fix this first</strong>
            <p>Timezone and egress region disagree.</p>
          </div>
        </div>
        <dl class="console-grid">
          <div>
            <dt>Locale</dt>
            <dd>en-US</dd>
          </div>
          <div>
            <dt>Timezone</dt>
            <dd>America/New_York</dd>
          </div>
          <div>
            <dt>Network</dt>
            <dd>GB / ASN</dd>
          </div>
          <div>
            <dt>CI</dt>
            <dd>fail-under 90</dd>
          </div>
        </dl>
        <pre><code>{`use: {
  locale: "en-US",
  timezoneId: "America/New_York",
  hasTouch: false
}`}</code></pre>
      </div>
    </section>

    <div id="scanner"></div>
    <EnvironmentScanner client:load />

    <div class="section-spacer"></div>
    <PresetGenerator client:visible />
  </section>
</BaseLayout>
